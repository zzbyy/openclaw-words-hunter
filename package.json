{
  "name": "words-hunter-openclaw",
  "version": "1.2.0",
  "description": "Master vocabulary captured by Words Hunter via conversational AI sessions.",
  "license": "MIT",
  "keywords": [
    "openclaw",
    "obsidian",
    "vocabulary",
    "words-hunter",
    "plugin"
  ],
  "homepage": "https://github.com/zzbyy/openclaw-words-hunter#readme",
  "bugs": {
    "url": "https://github.com/zzbyy/openclaw-words-hunter/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zzbyy/openclaw-words-hunter.git"
  },
  "main": "dist/index.js",
  "bin": {
    "words-hunter": "./dist/cli/repair.js"
  },
  "type": "module",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "SKILL.md",
    "README.md",
    "LICENSE"
  ],
  "openclaw": {
    "id": "words-hunter",
    "name": "Words Hunter",
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.22",
      "minGatewayVersion": "2026.3.22"
    }
  },
  "scripts": {
    "prepack": "npm run build",
    "postinstall": "node -e \"try{require('./dist/cli/postinstall.js')}catch{}\"",
    "build": "tsc",
    "repair": "node dist/cli/repair.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:evals": "vitest run tests/evals"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "chokidar": "^5.0.0",
    "proper-lockfile": "^4.1.2"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@types/proper-lockfile": "^4.1.4",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  }
}
